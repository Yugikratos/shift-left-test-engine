# Shift-Left Test Data Engine — Configuration
# Copy this file to .env and fill in your values

# Claude API Key (Optional — system works without it using rule-based fallback)
# Get your key from: https://console.anthropic.com
ANTHROPIC_API_KEY=

# LLM Model (default: claude-sonnet-4-20250514)
LLM_MODEL=claude-sonnet-4-20250514

# Database (default: SQLite local file)
DATABASE_URL=sqlite:///./test_data_engine.db

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# API Server
API_HOST=0.0.0.0
API_PORT=8000
