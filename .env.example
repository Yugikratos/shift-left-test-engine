# Shift-Left Test Data Engine — Configuration
# Copy this file to .env and fill in your values

# LLM Provider: ANTHROPIC (default) or BEDROCK
LLM_PROVIDER=ANTHROPIC

# Claude API Key (Optional — system works without it using rule-based fallback)
# Get your key from: https://console.anthropic.com
ANTHROPIC_API_KEY=

# LLM Model (default: claude-sonnet-4-20250514)
LLM_MODEL=claude-sonnet-4-20250514

# AWS Bedrock (only needed if LLM_PROVIDER=BEDROCK)
# AWS_DEFAULT_REGION=us-east-1

# Database (default: SQLite local files)
DATABASE_URL=sqlite:///./test_data_engine.db
TARGET_DB_URL=sqlite:///./target_test.db

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# API Server
API_HOST=0.0.0.0
API_PORT=8000

# Enterprise Mode (generates XFR/BTEQ scripts instead of local execution)
# ENTERPRISE_MODE=false

# Enterprise SSH hosts (only needed if ENTERPRISE_MODE=true)
# ETL_SSH_HOST=rhel-etl-prod.internal
# ETL_SSH_USER=ab_svc
# TD_SSH_HOST=td-etl-prod.internal
# TD_SSH_USER=td_svc

# Path overrides (defaults to project subdirectories)
# MOCK_DATA_DIR=/path/to/mock_data
# KNOWLEDGE_BASE_DIR=/path/to/knowledge_base
# DML_DIR=/path/to/dml
# DDL_DIR=/path/to/ddl
